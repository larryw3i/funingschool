msgstr "    安装 fnschool 并运行它"

#: /home/larry/Git/larryw3i/funingschool/helper/docs/write_readme.py:112
msgid "Run the command line application:"
msgstr "运行`命令行`（航站楼）应用："

#: /home/larry/Git/larryw3i/funingschool/helper/docs/write_readme.py:113
msgid "* `Debian|Ubuntu`: `Ctrl+Alt+T`."
msgstr "* `Debian 或 Ubuntu`：`Ctrl+Alt+T`。"

#: /home/larry/Git/larryw3i/funingschool/helper/docs/write_readme.py:114
msgid "* `Windows`: \"`Win+R, powershell, Enter`\"."
msgstr "* `Windows`：\"`Win+R（同时按）, 输入“powershell”, 按 Enter`\"。"

#: /home/larry/Git/larryw3i/funingschool/helper/docs/write_readme.py:116
msgid "Enter the following commands:"
msgstr "复制粘贴以下命令："

#: /home/larry/Git/larryw3i/funingschool/helper/docs/write_readme.py:122
msgid ""
"# You may use the virtual enviroment on `Debian` or `Ubuntu`, the commands:"
msgstr "# 在 `Debian` 或 `Ubuntu` 机器上，你可能要使用虚拟环境，其命令："

#: /home/larry/Git/larryw3i/funingschool/helper/docs/write_readme.py:125
msgid ""
"python -m venv --system-site-packages ~/pyvenv; # Create virtual enviroment."
msgstr "python -m venv --system-site-packages ~/pyvenv; # 初次创建。"

#: /home/larry/Git/larryw3i/funingschool/helper/docs/write_readme.py:127
msgid ". ~/pyvenv/bin/activate; # Use it."
msgstr ". ~/pyvenv/bin/activate; # 后续使用。"

#: /home/larry/Git/larryw3i/funingschool/helper/docs/write_readme.py:128
msgid "# Install or update \"fnschool\"."
msgstr ""
"# 由于网络堵塞，安装 `fnschool` 时会出现访问不到 PyPI 源或网速慢的情形。由"
"此，建议您设置访问源为镜像源，这样做便于您安装和更新（任意一个即可）：\n"
"pip config set global.index-url https://mirrors.bfsu.edu.cn/pypi/web/simple "
"# BFSU PyPI 镜像。\n"
"pip config set global.index-url https://mirrors.pku.edu.cn/pypi/web/simple # "
"mirrors.pku.edu.cn PyPI 镜像。\n"
"pip config set global.index-url https://mirrors.tuna.tsinghua.edu.cn/pypi/"
"web/simple # TUNA PyPI 镜像。\n"
"## 如需其它 PyPI 镜像请自行参考 https://mirrors.cernet.edu.cn/list/pypi 。\n"
"# 安装 或 更新 `fnschool` 。"

